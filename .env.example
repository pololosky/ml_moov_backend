# ── Base de données PostgreSQL ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/moov_ml

# ── CORS (séparer par virgule si plusieurs origines) ────────────────────────
CORS_ORIGINS=http://localhost:3000

# ── Chemins des modèles ML ──────────────────────────────────────────────────
ML_MODELS_PATH=./models

# ── Seuils de décision ML ───────────────────────────────────────────────────
SCORE_THRESHOLD_CHURN=0.5
SCORE_THRESHOLD_FRAUDE=0.5

# ── Job de recalcul features ────────────────────────────────────────────────
RETRAIN_INTERVAL_MINUTES=15
